@startuml Reservation Sequence
header Massage Reservation System
actor "User/Admin" as Client
participant "Postman / Client" as Postman
participant "Middleware: Auth" as Auth
participant "Controller: Reservation" as Controller
database "MongoDB" as DB

Client -> Postman : POST /massage-shops/:shopId/reservations\n{ date, duration }
Postman -> Auth : Request with Bearer Token
Auth -> Auth : protect() : Verify Token
Auth -> DB : User.findById(decodedId)
DB --> Auth : user object
Auth -> Controller : next() with req.user

Controller -> DB : MassageShop.findById(shopId)
DB --> Controller : massageShop object

alt #LightPink [Shop Not Found]
    Controller -> Postman : 404 Not Found
else [Shop Exists]
    
    Controller -> Controller : Calculate totalStartMinutes & totalEndMinutes
    
    alt #LightYellow [Outside Business Hours or EndTime > CloseTime]
        Controller -> Postman : 400 Bad Request\n(Out of range or finish after closing)
    else [Within Business Hours]
        Controller -> DB : Reservation.find({ user: req.user.id })
        DB --> Controller : existedReservations[]

        alt #LightSalmon [count >= 3 AND role != 'admin']
            Controller -> Postman : 400 Bad Request\n(Exceeded max 3 reservations)
        else [Success Case]
            Controller -> DB : Reservation.create(req.body)
            DB --> Controller : success
            Controller -> Postman : 201 Created
        end
    end
end
@enduml